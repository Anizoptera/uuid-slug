{
  "name": "@anizoptera/uuid-slug",
  "version": "0.1.0",
  "description": "Zero-dependency UUID v4/v7 generation, direct base64url slugs, and configurable masked UUID slugs.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "NOTICE",
    "AGENTS.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "deno": "./dist/web/index.js",
      "browser": "./dist/web/index.js",
      "node": "./dist/node/index.js",
      "default": "./dist/web/index.js"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#runtime": {
      "bun": "./src/runtime/bun.ts",
      "deno": "./src/runtime/web.ts",
      "browser": "./src/runtime/web.ts",
      "node": "./src/runtime/node.ts",
      "default": "./src/runtime/web.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check": "bun run format:check && bun run typecheck && bun run test && bun run build && bun run bench:smoke && bunx publint && bunx @arethetypeswrong/cli --pack . --profile esm-only && bun run artifact:check",
    "clean": "rm -rf dist bench/reports",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "prepublishOnly": "publish-clean --guard-only",
    "publish:clean": "publish-clean -- --access public",
    "test": "bunx vitest run && bun test test/*.bun.test.ts",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "bench:smoke": "bun bench/run.ts --smoke",
    "bench:full": "bun bench/run.ts",
    "artifact:check": "bun scripts/check-artifact.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@anizoptera/publish-clean": "github:Anizoptera/publish-clean#6fe8fff46c8a1b067b0f2d422136153b3b006f5e",
    "@arethetypeswrong/cli": "^0.18.2",
    "@kripod/uuidv7": "^0.3.4",
    "@types/bun": "^1.3.13",
    "@types/node": "^24.10.0",
    "fastv7": "^1.0.2",
    "playwright": "^1.57.0",
    "prettier": "^3.8.3",
    "publint": "^0.3.20",
    "tsdown": "^0.16.8",
    "typescript": "^5.9.3",
    "uuid": "^14.0.0",
    "uuidv7": "^1.2.1",
    "uuidv7-js": "^2.0.0",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "unrun": "0.2.13"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
