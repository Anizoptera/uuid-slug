{
  "compilerOptions": {
    "customConditions": ["bun", "deno", "browser"],
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "bench/**/*.ts",
    "scripts/**/*.ts",
    "tsdown.config.ts",
    "vitest.config.ts"
  ]
}
